# AI Agent Platform 环境变量配置示例

# 数据库配置
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ai_agent_platform
DB_USERNAME=ai_agent
DB_PASSWORD=ai_agent123456
DB_ROOT_PASSWORD=root123456

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 配置
JWT_SECRET=ai-agent-platform-jwt-secret-change-this-in-production
JWT_EXPIRES_IN=7d

# 应用配置
NODE_ENV=production
PORT=3000

# 模型 API Keys
GLM_API_KEY=your-glm-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
QWEN_API_KEY=your-qwen-api-key-here

# 日志级别
LOG_LEVEL=info
